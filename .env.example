PG_USERNAME="your_email@example.com"
PG_PASSWORD="your_password"
# NOTE: must be quoted — dotenv treats `#` as a comment, which would strip /#/Login.
LOGIN_URL="https://thekallang.perfectgym.com/clientportal2/#/Login"
HEADLESS=true

# What to book — match exactly what the site renders. eg. Volleyball Courts
FACILITY_TYPE="Tennis Outdoor Courts"
# Date format: D/M with no leading zeros (e.g. 23/5, 22/8) — must match the
# calendar header text exactly.
BOOKING_DATE="25/5"
# Start time format: HH:MM AM/PM (e.g. 07:00 AM, 08:00 AM).
START_TIME="01:00 PM"
